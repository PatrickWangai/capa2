# ═══════════════════════════════════════════════════════════
#  Capa — Environment Variables
#  Copy to .env and fill in your values before running.
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://capa:capadev@localhost:5432/capa
# For Docker: postgresql://capa:capadev@postgres:5432/capa

# ── Cache (Redis) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For Docker with password: redis://:redisdev@redis:6379

# ── JWT Auth ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Required — no insecure default is used if these are unset, the app will refuse to start.
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-another-64-char-random-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ── Error monitoring (Sentry) ────────────────────────────
# Optional — leave unset to disable. Get a DSN from sentry.io.
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# ── AWS S3 (KYC document storage) ────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=capa-kyc-documents

# ── Email (SMTP / SendGrid) ──────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@capa.invest

# ── M-Pesa (Safaricom Daraja API) ────────────────────────
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_PASSKEY=your-daraja-passkey
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox
# Change to https://your-domain.com/api/webhooks/mpesa in production
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/webhooks/mpesa
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this AND append ?key=<same value> to MPESA_CALLBACK_URL registered with Daraja —
# without it, anyone who finds the webhook URL can forge deposit confirmations.
MPESA_WEBHOOK_SECRET=

# ── Alpaca (US equities broker) ──────────────────────────
# Paper trading: https://paper-api.alpaca.markets
# Live trading:  https://api.alpaca.markets
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Market Data (Polygon.io) ─────────────────────────────
POLYGON_API_KEY=your-polygon-io-api-key

# ── Docker Compose secrets ───────────────────────────────
POSTGRES_PASSWORD=capadev
REDIS_PASSWORD=redisdev
