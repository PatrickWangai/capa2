function sendEmail(productName, productCategoryName, contactName, contactEmail, contactPhone, contactComment) {
                var mailsArrayLife = ["janet.mavisi@jubileekenya.com","lavender.asiko@jubileekenya.com","onlinesales@jubileekenya.com"];
        var mailsArrayHealth = ["digitalsaleshealth@jubileekenya.com"];
        var mailsArrayGeneral = ["talk2us@allianz.com"];
        var mailsArrayAsset = ["jamlcustomerservice@jubileekenya.com"];
        var mailBaseUrl="https://5v1g4d.api.infobip.com/email/3/send";
        var mailFrom="None-reply@jubileeinsurance.com";
        var mailAuthDetails="digitalapps.jubileehealth:Jubilee@321";
        var emailStuff = new FormData();
    emailStuff.append("from", mailFrom);

    
        if (productCategoryName.includes("Life")) {
            mailsArrayLife.forEach(function (email) {
                emailStuff.append("to", email);
            });

        }
        else if (productCategoryName.includes("Health")) {
            mailsArrayHealth.forEach(function (email) {
                emailStuff.append("to", email);
            });

        } 
        else if (productCategoryName.includes("General")) {
            mailsArrayGeneral.forEach(function (email) {
                emailStuff.append("to", email);
            });
        }
        else if (productCategoryName.includes("Asset")) {
            mailsArrayAsset.forEach(function (email) {
                emailStuff.append("to", email);
            });

        }
        else {
            mailsArrayAsset.forEach(function (email) {
                emailStuff.append("to", email);
            });

    }
    var dependantCount = $("#dependantCount").val() === "" ? "N/A" : $("#dependantCount").val();
    var budgetCost = $("#budgetCost").val() === "" ? "N/A" : $("#budgetCost").val();
    var hasBudgetCostCorporate = $("#hasBudgetCostCorporate").val() === "No" ? $("#hasBudgetCostCorporate").val() : $("#hasBudgetCostCorporate").val();
    var budgetCostCorporate = $("#budgetCostCorporate").val() === "" ? "N/A" : $("#budgetCostCorporate").val();
    var spouseAge = $("#spouseAge").val() === "" ? "N/A" : $("#spouseAge").val();
    var individualPlusSpouse = $("#individualPlusSpouse").val() === "No" ? $("#individualPlusSpouse").val() : $("#individualPlusSpouse").val();
    var individualPlusSpouseBudgetCost = $("#individualPlusSpouseBudgetCost").val() === "" ? "N/A" : $("#individualPlusSpouseBudgetCost").val();
    var individualCompany = $("#individualCompany").val() === "Company" ? $("#individualCompany").val() : $("#individualCompany").val();
    var individualCompanyBudgetCost = $("#individualCompanyBudgetCost").val() === "" ? "N/A" : $("#individualCompanyBudgetCost").val();
    var employeeCountInternational = $("#employeeCountInternational").val() === "" ? "N/A" : $("#employeeCountInternational").val();
    var contactComment = $("#comment").val() === "" ? "N/A" : $("#comment").val();

    emailStuff.append("subject", productCategoryName + ":" + productName);
    if (productName === "J-Care Medical Cover" || productName === "J-Care Johari Medical Cover" || productName === "CoverBora Medical Cover") {
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nCover Requirements: " + $("#individualFamily").val() + "\nNumber of Dependants: " + dependantCount + "\nEstimated budget: " + budgetCost + "\nComment: " + contactComment);
    }
    else if (productName === "J-Biz SME Medical Cover" || productName === "Corporate Cover" || productName === "Group Health Cover") {
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nNumber of Employees: " + $("#employeeCount").val() + "\nBudget Cost Available" + hasBudgetCostCorporate + "\nEstimated budget: " + budgetCostCorporate + "\nComment: " + contactComment);
    }
    else if (productName === "J-Senior Medical Cover") {
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + $("#phoneSenior").val() + "\nEmail Address: " + contactEmail + "\nCover for Self Plus Spouse: " + individualPlusSpouse + "\nRequester's age: " + $("#individualAge").val() + "\nSpouse's age: " + spouseAge + "\nEstimated budget: " + individualPlusSpouseBudgetCost + "\nComment: " + contactComment);
    }
    else if (productName === "Care & Health") {
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nCover Requirements: " + individualCompany + "\nNumber of Employees: " + employeeCountInternational + "\nEstimated budget: " + individualCompanyBudgetCost + "\nComment: " + contactComment);
    }
    else {
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nComment: " + contactComment);
    }
        
        $.ajax({
            url: mailBaseUrl,
            type: 'POST',
            contentType: false,
            processData: false,
            data: emailStuff,
            beforeSend: function (xhr) {
                xhr.setRequestHeader('Authorization', "Basic " + btoa(mailAuthDetails));
            },
            success: function (data) {
                console.log("Mail Sent");
            },
            error: function (e) {
                console.log(JSON.stringify(e));
            }
        });
        return false;
    }

function sendCallbackEmail(contactName, contactEmail, contactPhone, contactIssue, contactComment) {
                var mailsArrayCallback = ["Talk2Us@jubileekenya.com"];
        var mailBaseUrl = "https://5v1g4d.api.infobip.com/email/3/send";
        var mailFrom = "None-reply@jubileeinsurance.com";
        var mailAuthDetails = "digitalapps.jubileehealth:Jubilee@321";
        var emailStuff = new FormData();
        emailStuff.append("from", "Jubilee Kenya Customer Requests<"+mailFrom+">");
        mailsArrayCallback.forEach(function (email) {
            emailStuff.append("to", email);
        });
        emailStuff.append("subject", "Customer Issue:" + contactIssue);
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nComment: " + contactComment);

        $.ajax({
            url: mailBaseUrl,
            type: 'POST',
            contentType: false,
            processData: false,
            data: emailStuff,
            beforeSend: function (xhr) {
                xhr.setRequestHeader('Authorization', "Basic " + btoa(mailAuthDetails));
            },
            success: function (data) {
                console.log("Mail Sent");
            },
            error: function (e) {
                console.log(JSON.stringify(e));
            }
        });
        return false;
    }
    
    function sendCallbackWellnessEmail(contactName, contactEmail, contactPhone, contactRequest, contactIsInsured, contactIsPregnant, contactIsWithBaby, contactWantsUpdates) {
                var mailsArrayCallback = ["wellness@jubileekenya.com","Samuel.Murani@jubileekenya.com"];
        var mailBaseUrl = "https://5v1g4d.api.infobip.com/email/3/send";
        var mailFrom = "None-reply@jubileeinsurance.com";
        var mailAuthDetails = "digitalapps.jubileehealth:Jubilee@321";
        var emailStuff = new FormData();
        emailStuff.append("from", "Jubilee Kenya Maishafiti Customer Requests<" + mailFrom + ">");
        mailsArrayCallback.forEach(function(email) {
            emailStuff.append("to", email);
        });
        var isInsured = contactIsInsured == "1" ? "Yes" : "No";
        var isPregnant = contactIsPregnant == "1" ? "Yes" : "No";
        var isWithBaby = contactIsWithBaby == "1" ? "Yes" : "No";
        var wantUpdates = contactWantsUpdates == "1" ? "Yes" : "No";

        emailStuff.append("subject", "Customer Product Request:" + contactRequest);
        emailStuff.append("text", 'Name: ' + contactName + "\nPhone Number: " + contactPhone + "\nEmail Address: " + contactEmail + "\nIs Insured: " + isInsured  + "\nIs Pregnant: " + isPregnant+ "\nIs With Baby: " + isWithBaby  + "\nWants Updates: " + wantUpdates);

        $.ajax({
            url: mailBaseUrl,
            type: 'POST',
            contentType: false,
            processData: false,
            data: emailStuff,
            beforeSend: function(xhr) {
                xhr.setRequestHeader('Authorization', "Basic " + btoa(mailAuthDetails));
            },
            success: function(data) {
                console.log("Mail Sent");
            },
            error: function(e) {
                console.log(JSON.stringify(e));
            }
        });
        return false;
    }


    $(document).ready(function() {

        // alert($(".block:hidden").length);
        // console.log($(".block").length);
        $length = $(".block").length;

        $(".block").slice(0, $length).hide();
        $(".block").slice(0, 6).show();

        if ($(".block:hidden").length != 0) {
            $("#load").show();
        } else {
            // $("#load").hide()
        }

        $("#load").on("click", function(e) {
            e.preventDefault();
            $(".block:hidden").slice(0, 3).slideDown();
            if ($(".block:hidden").length == 0) {
                $("#load").hide()
            }
        });
    });

    // $(document).ready(function () {
    function myfilter() {
        var input = document.getElementById('Search');
        console.log(input);
        var filter = input.value.toLowerCase();
        var nodes = document.getElementsByClassName('promo-search');

        for (i = 0; i < nodes.length; i++) {
            if (nodes[i].innerText.toLowerCase().includes(filter)) {
                nodes[i].style.display = 'block';
            } else {
                nodes[i].style.display = 'none';
            }
        }
    }

    function myfilter2() {
        var $input = $("#Search2").val();
        var $tax = $("#tax").val();
        var $pid = $("#pid").val();
        console.log($("input[type='checkbox']"));
        // console.log($tax);

        event.preventDefault();
        $.ajax({
            type: 'POST',
            url: 'https://jubileeinsurance.com/ke/wp-content/themes/jubilee/ajaxdata/data.php',
            data: {
                s: $input,
                pid: $pid,
                tax: $tax,
            },
            success: function(results) {
                $('.olddata').remove();
                $('#datafetch').html(results);
            }
        });
        return false;

    }


    $(document).ready(function(){
        if($("#facilityFilter").val()!=="") {
            getRelatedServices();
        }
    });
    function getRelatedServices() {
        var $input = $("#facilityFilter").val();

        $('#serviceFilter').find('option').not(':first').remove();
        $.ajax({
            type: 'POST',
            url: 'https://jubileeinsurance.com/ke/wp-content/themes/jubilee/ajaxdata/categoryFilter.php',
            data: {
                facility: $input,
            },
            success: function (results) {
                var len = 0;
                var information=$.parseJSON(results);
                if (results != null) {
                    len = information.length;
                    if (len > 0) {
                        for (var i = 0; i < len; i++) {
                            var id = information[i].slug;
                            var service = information[i].name;
                            var option = "<option value='" + id + "'>" + service +
                                "</option>";
                            $("#serviceFilter").append(option);
                        }
                    }
                }
               // console.log(results);
            }
        });
    }

    function filterFacilities() {
        if($("#facilityFilter").val()!=="") {
            getRelatedServices();
        }
        var valFacilities = $("#facilityFilter").val();
        var valService = $("#serviceFilter").val();
        var $input = $("#locationFilter").val();
        var $tax = $("#tax").val();
        var $pid = $("#pid").val();
        var $action = $("#action").val();
        var $actionMore = $("#actionMore").val();
        var $specialist = $("#speciaList").val();

        $.ajax({
            type: 'POST',
            url: 'https://jubileeinsurance.com/ke/wp-content/themes/jubilee/ajaxdata/data.php',
            data: {
                s: $input,
                facility: valFacilities,
                service: valService,
                pid: $pid,
                tax: $tax,
                action: $action,
                actionMore: $actionMore,
                specialist: $specialist
            },
            success: function (results) {
                $('.olddata').remove();
                $('#datafetch').html(results);
                $length = $(".block").length;

                $(".block").slice(0, $length).hide();
                $(".block").slice(0, 6).show();

                if ($(".block:hidden").length != 0) {
                    $("#load").show();
                } else {
                    // $("#load").hide()
                }

               // console.log(results);
            }
        });


    }

